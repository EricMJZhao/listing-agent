# 复制这个文件为 .env，把下面这行换成你的真实 API Key
# 官方直连：去 https://console.anthropic.com/ 拿 Key
# 公司中转：问你们内部平台
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 如果你用公司/内部中转服务，把这行解开注释，改成公司给你的地址 ===
# 官方直连用户：这一行留着注释就行
# ANTHROPIC_BASE_URL=https://bmc-llm-relay.bluemediagroup.cn

# === 可选：模型切换（省钱 or 换支持列表里的） ===
# 官方支持: claude-opus-4-8 / claude-sonnet-5 / claude-haiku-4-5
# 中转服务可能只支持部分模型，问你们内部平台或看返回错误决定
# LISTING_AGENT_MODEL=claude-sonnet-5
