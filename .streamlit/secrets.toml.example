# === 部署时的 secrets 模板 ===
# 本地部署:复制成 .env(项目根目录)
# Streamlit Cloud 部署:粘贴到 App Settings → Secrets(不含 [default] 前缀)

# 生产用 Anthropic 官方 Key(不用公司中转)
ANTHROPIC_API_KEY = "sk-ant-your-real-key-here"

# ⚠️ 生产环境不要设置 ANTHROPIC_BASE_URL,让 SDK 走官方地址
# ANTHROPIC_BASE_URL = ""

# 模型选择(生产建议 sonnet-5 省钱,或保留 opus-4-8 顶配)
LISTING_AGENT_MODEL = "claude-sonnet-5"
